{
  "name": "phenix-null-eden",
  "productName": "PHENIX: NULL EDEN",
  "version": "1.0.0",
  "description": "A cyber-survival roguelite by InkSpireM Visuals",
  "main": "main.js",
  "author": "InkSpireM Visuals",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "steamworks.js": "^0.4.1"
  },
  "build": {
    "appId": "com.inkspirem.phenixnulleden",
    "productName": "PHENIX NULL EDEN",
    "files": ["main.js", "preload.js", "game/**/*"],
    "win": { "target": ["nsis", "portable"], "icon": "game/assets/pwa/icon-512.png" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  }
}
